<%= form_with(model: account, class: "space-y-6") do |form| %>
  <% if account.errors.any? %>
    <div class="alert alert-error">
      <div>
        <h3 class="font-bold"><%= pluralize(account.errors.count, "error") %> prevented this account from being saved:</h3>
        <ul class="list-disc list-inside">
          <% account.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
  <div class="form-control">
    <%= form.label :name, class: "label" do %>
      <span class="label-text">Name</span>
    <% end %>
    <%= form.text_field :name, required: true, class: "input input-bordered w-full" %>
  </div>
  <div class="form-control">
    <%= form.label :account_type, class: "label" do %>
      <span class="label-text">Account Type</span>
    <% end %>
    <%= form.select :account_type,
          Account.account_types.keys.map { |k| [k.humanize, k] },
          { prompt: "Select account type" },
          { class: "select select-bordered w-full", required: true } %>
  </div>
  <div class="form-control">
    <%= form.submit "Save Account", class: "btn btn-primary" %>
  </div>
<% end %>
