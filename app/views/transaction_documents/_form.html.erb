<%= form_with(model: transaction_document) do |form| %>
  <% if transaction_document.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(transaction_document.errors.count, "error") %> prohibited this transaction_document from being saved:</h2>

      <ul>
        <% transaction_document.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :transaction_id, style: "display: block" %>
    <%= form.number_field :transaction_id %>
  </div>

  <div>
    <%= form.label :filepath, style: "display: block" %>
    <%= form.text_field :filepath %>
  </div>

