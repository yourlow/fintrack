<%= form_with(model: transaction) do |form| %>
  <% if transaction.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(transaction.errors.count, "error") %> prohibited this transaction from being saved:</h2>
      <ul>
        <% transaction.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :raw_description, style: "display: block" %>
    <%= form.text_field :raw_description, class: "input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :user_description, style: "display: block" %>
    <%= form.text_field :user_description, class: "input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :amount, style: "display: block" %>
    <%= form.number_field :amount, class: "input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
