<p class="text-green-600"><%= notice %></p>

<% content_for :title, "Transactions" %>

<h1 class="text-2xl font-semibold tracking-tight mb-6">Transactions</h1>

<div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Date</th>
        <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Raw Description</th>
        <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-gray-600">User Description</th>
        <th scope="col" class="px-4 py-3 text-right text-sm font-semibold text-gray-600">Amount</th>
        <th scope="col" class="px-4 py-3 text-right text-sm font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 bg-white">
      <% @transactions.each do |transaction| %>
        <tr>
          <td class="px-4 py-3 text-sm text-gray-900">
            <%= transaction.transaction_date&.strftime("%Y-%m-%d") %>
          </td>
          <td class="px-4 py-3 text-sm text-gray-900"><%= transaction.raw_description %></td>
          <td class="px-4 py-3 text-sm text-gray-900"><%= transaction.user_description %></td>
          <td class="px-4 py-3 text-sm text-right text-gray-900">
            <%= number_to_currency(transaction.amount.to_f / 100) %>
          </td>
          <td class="px-4 py-3 text-sm text-right space-x-2">
            <%= link_to "Show", transaction, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
            <%= link_to "Edit", edit_transaction_path(transaction), class: "text-blue-600 hover:text-blue-900 font-medium" %>
            <%= link_to "Delete", transaction, method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900 font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= link_to "New transaction", new_transaction_path,
        class: "inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-white font-medium shadow hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
</div>
